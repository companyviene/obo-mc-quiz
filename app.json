{
  "expo": {
    "name": "OBO MC Quiz",
    "slug": "obo-mc-quiz",
    "scheme": "oboquiz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/obo-mc-logo-color.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/obo-mc-logo-color.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.obomasterclass.quiz"
    },
    "android": {
      "package": "com.obomasterclass.quiz",
      "adaptiveIcon": {
        "foregroundImage": "./assets/obo-mc-favicon-color.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/obo-mc-favicon-color.png",
      "name": "OBO MC Quiz",
      "shortName": "OBO MC Quiz",
      "description": "Mini-capsules vidéo de formation – quiz.obomasterclass.com",
      "themeColor": "#0f0f1a",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
